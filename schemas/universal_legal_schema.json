      "to": "Regional Transport Officer / Jurisdictional Magistrate",
      "subject_pattern": "Challenge to Motor Vehicle Challan — Absence of Mandatory Speed Limit Signage (MoRTH IRC:67 / Section 208 MVA 1988)",
      "grounds": [
        "No speed limit sign (IRC:67 compliant) detected within 500m upstream of enforcement camera location.",
        "Absence of mandatory signage renders challan legally untenable per Section 208 MVA 1988.",
        "Telemetry evidence (GPS trace, vision log, timestamp) attached as Annexure A.",
        "Request production of NHAI/PWD sign installation record for cited road segment."
      ],
      "annexure_A_fields": ["timestamp_epoch_ms", "gps_lat", "gps_lon", "camera_gps_lat", "camera_gps_lon", "vision_detection_log_hash", "imu_speed_kmh"],
