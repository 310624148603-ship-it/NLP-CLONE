    "protocol_id": "SEC_208_AUDIT",
    "trigger_statute": "Motor Vehicles Act, 1988, Section 208",
    "description": "If a speed camera is detected but no mandatory speed sign exists within the preceding 500m, generate a legally-binding Audit Request challenging the challan on infrastructural failure grounds.",
